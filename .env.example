# ============================================================================
# Conviction Room — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================================================

# --------------------------------------------------------------------------
# 1. AI / LLM PROVIDERS
# --------------------------------------------------------------------------

# OpenAI  (primary for structured outputs + reasoning)
# Signup: https://platform.openai.com/signup
# Keys:   https://platform.openai.com/api-keys
# Free:   No free tier anymore. ~$5 minimum deposit required.
# Cost:   GPT-4o ~$2.50/1M input, $10/1M output
OPENAI_API_KEY=sk-...

# OpenRouter  (unified gateway to 400+ models, 27 free models)
# Signup: https://openrouter.ai
# Keys:   Dashboard → API Keys → Create Key
# Free:   27 models free, 50 req/day (1,000/day with $10+ credits)
# Supports structured outputs + function calling on compatible models
OPENROUTER_API_KEY=sk-or-...

# Google Gemini  (best free tier for high-volume extraction)
# Signup: https://aistudio.google.com
# Keys:   Google AI Studio → Get API Key
# Free:   No credit card. 2.5 Flash: 10 RPM, 250 RPD. Flash-Lite: 30 RPM, 1000 RPD.
# Supports JSON mode / structured outputs
GEMINI_API_KEY=AIza...

# Anthropic Claude  (strong reasoning, good for arbiter/cross-exam)
# Signup: https://console.anthropic.com
# Keys:   Console → API Keys
# Free:   $5 free credits for new accounts, no credit card required
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek  (cheapest paid option, strong reasoning)
# Signup: https://platform.deepseek.com
# Keys:   Platform → API Keys
# Free:   5M free tokens for new accounts, no credit card
# Cost:   V3 ~$0.28/1M input, R1 ~$0.50/1M input
DEEPSEEK_API_KEY=sk-...

# Groq  (fastest inference, good for extraction/classification)
# Signup: https://console.groq.com
# Keys:   Console → API Keys
# Free:   No credit card. 30 RPM, 1,000 req/day on free tier
GROQ_API_KEY=gsk_...

# --------------------------------------------------------------------------
# 2. WEB SEARCH / RETRIEVAL
# --------------------------------------------------------------------------

# Tavily  (purpose-built for AI agents, LangChain default)
# Signup: https://app.tavily.com
# Keys:   Dashboard → API Key section
# Free:   1,000 API credits/month, no credit card
TAVILY_API_KEY=tvly-...

# Brave Search  (independent index, generous free tier)
# Signup: https://brave.com/search/api/
# Keys:   API Dashboard → Add API Key
# Free:   2,000 queries/month, 1 req/sec
BRAVE_SEARCH_API_KEY=BSA...

# --------------------------------------------------------------------------
# 3. WEB SCRAPING
# --------------------------------------------------------------------------

# Apify  (10,000+ pre-built scrapers, financial data actors)
# Signup: https://apify.com
# Keys:   Settings → Integrations → API Token
# Free:   $5 platform credits/month, no credit card
APIFY_API_TOKEN=apify_api_...

# --------------------------------------------------------------------------
# 4. FINANCIAL DATA
# --------------------------------------------------------------------------

# Alpha Vantage  (stocks, ETFs, fundamentals, forex)
# Signup: https://www.alphavantage.co/support/#api-key
# Free:   25 requests/day, no credit card
ALPHA_VANTAGE_API_KEY=...

# Finnhub  (real-time quotes, company profiles, news, earnings)
# Signup: https://finnhub.io/register
# Keys:   Dashboard → API Key
# Free:   60 calls/minute, no credit card
FINNHUB_API_KEY=...

# CoinGecko  (crypto market data — already used in mini app template)
# Free:   Public endpoints, no key needed for basic use
# Signup: https://www.coingecko.com/en/api (for higher limits)
COINGECKO_API_KEY=

# --------------------------------------------------------------------------
# 5. DATABASE
# --------------------------------------------------------------------------

# PostgreSQL  (primary persistence)
# Option A — Neon (serverless, best free tier for Postgres)
#   Signup: https://neon.tech
#   Free:   0.5 GB storage/project, 100 CU-hours/month compute, no credit card
# Option B — Supabase
#   Signup: https://supabase.com
#   Free:   500 MB storage, 2 projects, no credit card
# Option C — Local
#   docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:16
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/conviction_room

# Redis  (optional — job queue, caching)
# Option A — Upstash (serverless Redis)
#   Signup: https://upstash.com
#   Free:   500K commands/month, no credit card
# Option B — Local
#   docker run -p 6379:6379 redis:7
REDIS_URL=redis://localhost:6379

# --------------------------------------------------------------------------
# 6. PAPER TRADING (Phase 9 — optional, not needed early)
# --------------------------------------------------------------------------

# Alpaca  (paper trading simulation, real-time market data)
# Signup: https://app.alpaca.markets/signup
# Keys:   Dashboard → API Keys → Generate
# Free:   Full paper trading, no credit card. 200 req/min.
ALPACA_API_KEY=...
ALPACA_SECRET_KEY=...
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --------------------------------------------------------------------------
# 7. LUFFA / ENDLESS (bot integration)
# --------------------------------------------------------------------------

# Luffa Bot SDK credentials — get from Luffa/Endless hackathon mentors
LUFFA_BOT_TOKEN=
LUFFA_BOT_SECRET=

# Endless network (devnet for hackathon)
ENDLESS_NETWORK=devnet
ENDLESS_WALLET_ADDRESS=
